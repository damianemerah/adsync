          <div className="w-full h-full flex items-center justify-center text-[10px] text-slate-400">
            No Image
          </div>
        )}

        {creatives.length > 1 && (
          <>
            <button
              onClick={() => setActiveIndex((prev) => Math.max(0, prev - 1))}
