            <div className="h-px bg-border flex-1" />
            <Input
              type="number"
              min={18}
              max={65}
              value={campaignStore.ageRange?.max || 65}
              onChange={(e) =>
                updateDraft({
                  ageRange: {
                    min: campaignStore.ageRange?.min || 18,
                    max: parseInt(e.target.value) || 65,
