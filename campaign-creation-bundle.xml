  { label: "💄 Beauty & Skincare", template: "I sell skincare and beauty products in {location}" },
  { label: "🍖 Food & Catering",   template: "I sell food and catering services in {location}" },
  { label: "💇 Wigs & Hair",       template: "I sell wigs and hair products in {location}" },
  { label: "📱 Electronics",       template: "I sell phones and electronics in {location}" },
