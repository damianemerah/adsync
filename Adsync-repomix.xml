            Join 2,000+ Nigerian businesses already selling more with Sellam.
          </p>
        </div>

        <div className="grid gap-6 md:grid-cols-2 lg:grid-cols-3 items-start">
          {chunks.map((chunk, colIndex) => (
            <div key={colIndex} className="grid gap-6">
