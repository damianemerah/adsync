    orgName,
    industry,
    businessDescription,
    sellingMethod,
    priceTier,
    customerGender,
    userRole,
    selectedPlan,
  ]);

  const progress = (step / 5) * 100;

  const handleNext = () => {
    if (step < 5) setStep(step + 1);
  };

  const handleBack = () => {
    if (step > 1) setStep(step - 1);
