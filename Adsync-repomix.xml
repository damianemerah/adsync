              name="orgName"
              placeholder="e.g. Acme Corp"
              required
            />
          </div>

          <DialogFooter>
            <Button
              type="button"
              variant="outline"
              onClick={() => setIsOpen(false)}
            >
              Cancel
            </Button>
            <Button type="submit" disabled={isLoading} className="bg-blue-600">
              {isLoading ? (
                <SystemRestart className="w-4 h-4 animate-spin" />
              ) : (
                "Create & Switch"
              )}
            </Button>
          </DialogFooter>
        </form>
      </DialogContent>
    </Dialog>
  );
}
