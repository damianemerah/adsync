        onOpenChange={setUploadModalOpen}
        onUploadComplete={(creative) => {
          toggleCreative(creative.original_url);
          setUploadModalOpen(false);
        }}
      />
      <PaymentDialog
        planId="growth"
        open={upgradeDialogOpen}
        onOpenChange={setUpgradeDialogOpen}
      />
    </>
  );
}
