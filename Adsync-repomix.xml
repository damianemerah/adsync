          showFacebookHeader ? "border-slate-200 bg-white" : "border-slate-50",
        )}
      >
        <div className="flex items-center gap-2">
          <Avatar className="h-7 w-7">
            <AvatarFallback
              className={cn(
                "text-[9px] font-bold",
                showFacebookHeader
                  ? "bg-blue-600 text-white"
