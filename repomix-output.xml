        {quota > 0 && (
          <div className="w-full bg-border rounded-full h-1.5 overflow-hidden">
            <div
              className={cn(
                "h-full rounded-full transition-all duration-500 ease-out",
                percentUsed >= 100
                  ? "bg-red-500"
                  : percentUsed >= 80
                    ? "bg-amber-400"
                    : "bg-primary",
              )}
              style={{ width: `${Math.min(percentUsed, 100)}%` }}
            />
          </div>
        )}
      </div>
    </Link>
  );
}
