      >
        <span className="text-xs sm:text-sm font-bold">
          {hasExtraStep ? "4" : "3"}.
        </span>
        <span className="text-xs sm:text-sm">Creative</span>
      </TabsTrigger>

      <TabsTrigger
        value={hasExtraStep ? "5" : "4"}
        disabled={!canGoTo.launch}
        className={cn(tabTriggerClass, disabledClass)}
      >
        <span className="text-xs sm:text-sm font-bold">
          {hasExtraStep ? "5" : "4"}.
