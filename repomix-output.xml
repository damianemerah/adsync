  --status-info-foreground: #030018;
  --status-info-soft: rgba(96, 165, 250, 0.12);

  /* Chart Palette — dark mode (slightly brighter, matching -soft tints) */
  --chart-1: #60a5fa;
  --chart-1-soft: rgba(96, 165, 250, 0.12);
  --chart-2: #f472b6;
  --chart-2-soft: rgba(244, 114, 182, 0.12);
  --chart-3: #a78bfa;
  --chart-3-soft: rgba(167, 139, 250, 0.12);
  --chart-4: #2dd4bf;
  --chart-4-soft: rgba(45, 212, 191, 0.12);
  --chart-5: #fb923c;
  --chart-5-soft: rgba(251, 146, 60, 0.12);
  --chart-6: #94a3b8;
  --chart-6-soft: rgba(148, 163, 184, 0.12);
}

@theme inline {
  --font-sans: "Montserrat", sans-serif;
  --font-heading: "Montserrat Alternates", sans-serif;

  /* Custom font-size tokens */
  --text-2xs: 0.8125rem; /* 13px */

  /* Use --color-* prefix for variables to become color utilities */
  --color-primary: var(--primary);
  --color-primary-foreground: var(--primary-foreground);
  --color-background: var(--background);
  --color-foreground: var(--foreground);
  --color-card: var(--card);
  --color-card-foreground: var(--card-foreground);
  --color-muted: var(--muted);
  --color-muted-foreground: var(--muted-foreground);
  --color-popover: var(--popover);
  --color-popover-foreground: var(--popover-foreground);
  --color-accent: var(--accent);
  --color-accent-foreground: var(--accent-foreground);
  --color-destructive: var(--destructive);
  --color-destructive-foreground: var(--destructive-foreground);
  --color-border: var(--border);
  --color-ring: var(--ring); /* This enables outline-ring and ring utilities */
  --color-sidebar: var(--sidebar);
  --color-subtle-foreground: var(--subtle-foreground);
  --color-sidebar-border: var(--sidebar-border);

  --radius-lg: var(--radius);
  --shadow-soft: 0 1px 2px 0 var(--shadow-color);
  --shadow-card: 0 0 0 1px var(--border);

  /* Status Utilities (text-status-success, bg-status-success-soft, etc.) */
  --color-status-success: var(--status-success);
  --color-status-success-foreground: var(--status-success-foreground);
  --color-status-success-soft: var(--status-success-soft);
  --color-status-warning: var(--status-warning);
  --color-status-warning-foreground: var(--status-warning-foreground);
  --color-status-warning-soft: var(--status-warning-soft);
  --color-status-danger: var(--status-danger);
  --color-status-danger-foreground: var(--status-danger-foreground);
  --color-status-danger-soft: var(--status-danger-soft);
  --color-status-info: var(--status-info);
  --color-status-info-foreground: var(--status-info-foreground);
  --color-status-info-soft: var(--status-info-soft);

  /* Chart Utilities (text-chart-1, bg-chart-1-soft, etc.) */
  --color-chart-1: var(--chart-1);
  --color-chart-1-soft: var(--chart-1-soft);
  --color-chart-2: var(--chart-2);
  --color-chart-2-soft: var(--chart-2-soft);
  --color-chart-3: var(--chart-3);
  --color-chart-3-soft: var(--chart-3-soft);
  --color-chart-4: var(--chart-4);
  --color-chart-4-soft: var(--chart-4-soft);
  --color-chart-5: var(--chart-5);
  --color-chart-5-soft: var(--chart-5-soft);
  --color-chart-6: var(--chart-6);
  --color-chart-6-soft: var(--chart-6-soft);

  /* Brand Utilities */
  --color-facebook: var(--facebook);
  --color-brand-meta: var(--brand-meta);
  --color-brand-tiktok: var(--brand-tiktok);
  --color-brand-tiktok-foreground: var(--brand-tiktok-foreground);
  --color-google: var(--google);
  --color-spotify: var(--spotify);
  --color-whatsapp: var(--whatsapp);

  /* AI Utilities */
  --color-ai: var(--ai);
  --color-ai-foreground: var(--ai-foreground);

  /* Warning Utilities */
  --color-warning-bg: var(--warning-bg);
  --color-warning-border: var(--warning-border);
  --color-warning-text: var(--warning-text);
  --color-warning-text-secondary: var(--warning-text-secondary);
  --color-warning-icon: var(--warning-icon);
  --color-warning-icon-bg: var(--warning-icon-bg);
  --color-warning-btn: var(--warning-btn);
  --color-warning-btn-hover: var(--warning-btn-hover);
}

@utility container {
  margin-inline: auto;
  padding-inline: 2rem;
  max-width: 1400px;
  width: 100%;

  @media (width >= 640px) {
    max-width: 640px;
  }
  @media (width >= 768px) {
    max-width: 768px;
  }
  @media (width >= 1024px) {
    max-width: 1024px;
  }
  @media (width >= 1280px) {
    max-width: 1280px;
  }
  @media (width >= 1536px) {
    max-width: 1400px;
  }
}

@layer base {
  /* Applying outline to focus states or global reset */
  *:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--ring) 50%, transparent);
  }


  body {
    background-color: var(--background);
    color: var(--foreground);
    font-family: var(--font-sans);
  }

  h1,
  h2,
  h3 {
    font-family: var(--font-heading);
  }

  .side-menu-sub-item {
    display: flex;
    align-items: center;
    gap: 8px;
    width: 100%;
    max-width: 200px;
    padding: 6px 8px;
    border-radius: 6px;
    background-color: transparent;
    color: var(--subtle-foreground);
    font-size: 14px;
    font-weight: 500;
    line-height: 1.25rem;
    cursor: pointer;
    transition: all 0.15s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .side-menu-item {
    align-items: center;
    border-radius: 6px;
    cursor: pointer;
    display: flex;
    font-size: 14px;
    font-weight: 500;
    gap: 12px;
    line-height: 20px;
    line-height: 1.25rem;
    margin-bottom: 6px;
    padding: 6px 8px;
    text-transform: capitalize;
    --tw-text-opacity: 1;
    color: var(--subtle-foreground);
  }

  .no-scrollbar {
    scrollbar-width: none; /* Firefox */
    -ms-overflow-style: none; /* IE / Edge */
  }

  .no-scrollbar::-webkit-scrollbar {
    display: none; /* Chrome / Safari / Opera */
  }

  .text-primary-foreground {
    color: var(--primary-foreground);
  }

  /* Phone input: reset library margin so country + input share one border */
.PhoneInputCountry {
  --PhoneInputCountrySelect-marginRight: 0;
}

