          className="w-full h-12 bg-primary hover:bg-primary/90 text-primary-foreground border border-border rounded-lg font-bold transition-all"
        >
          {isGenerating ? (
            <>
              <Sparks className="mr-2 h-4 w-4 animate-spin" /> Redesigning...
            </>
