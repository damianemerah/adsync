              </div>
              <div>
                <p className="text-sm font-semibold">{label}</p>
                {isFree ? (
                  <p className="text-xs font-bold text-green-600">FREE - {note}</p>
                ) : (
                  <p className="text-xs text-subtle-foreground">{credits} credit{credits !== 1 ? "s" : ""} - {note}</p>
                )}
