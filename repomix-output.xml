          )}
        </div>

        {/* Interest suggestions */}
        {(suggestions.length > 0 || loadingSuggestions) && (
          <div className="pt-1 space-y-1.5">
            <p className="text-xs text-subtle-foreground uppercase tracking-wider font-medium">
