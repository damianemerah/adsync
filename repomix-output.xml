                aspectRatio={aspectRatio}
                onAspectRatioChange={setAspectRatio}
                imageUrls={imageUrls}
                onImageUrlsChange={setImageUrls}
                format={creativeFormat}
                onFormatChange={setCreativeFormat}
              />

              <Button
                onClick={handleGenerate}
                disabled={isGenerating || !prompt}
