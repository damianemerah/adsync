// Primary: #12e193 (approx)
// Foreground: #020617
// Muted: #64748b

export const METRIC_CONFIG = {
  spend: {
    label: "Spend",
    color: "hsl(var(--primary))",
    icon: Dollar,
    theme: "blue",
  },
  impressions: {
    label: "Impressions",
    color: "#9333EA", // Purple - keep or align with branding? Let's keep distinct colors for charts but use HSL if possible
    icon: Eye,
    theme: "purple",
  },
  clicks: {
    label: "Clicks",
    color: "#2563EB", // Blue
    icon: CursorPointer,
    theme: "green",
