          type: "string" as const,
          enum: ["male", "female", "all"] as const,
        },
        priceTier: {
          type: "string" as const,
          enum: ["low", "mid", "high", "unknown"] as const,
        },
        businessType: {
          type: "string" as const,
          enum: [
            "fashion",
            "beauty",
            "food",
            "electronics",
            "events",
            "b2b",
            "software",
            "general",
            "unknown",
          ] as const,
        },
        lifeSignals: { type: "string" as const }, // comma-separated e.g. "wedding,job"
      },
