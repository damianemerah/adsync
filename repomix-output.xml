    | "food"
    | "electronics"
    | "events"
    | "b2b"
    | "general"
    | "unknown";
  confidence: number; // 0.0 – 1.0
  /** What the AI assumed when input was incomplete (shown to user for transparency) */
  inferred_assumptions?: string[];
