                  </div>
                  <div className="text-lg font-bold text-primary">
                    {roasPrediction.value.toFixed(1)}×
                  </div>
                </div>
              </div>

              <div className="space-y-3">
                <Button
                  variant="outline"
                  size="lg"
                  className="w-full h-12 rounded-2xl font-bold"
