@import url("https://fonts.googleapis.com/css2?family=Montserrat+Alternates:wght@700&family=Montserrat:wght@400;500;600;700&display=swap");
@import "tailwindcss";
@import "tw-animate-css";

@custom-variant dark (&:is(.dark *));

:root {
  /* Wask Brand Colors */
  --primary: #12e193;
  --primary-foreground: #ffffff;
  --background: #ffffff;
  --foreground: #030018;

  /* Card / Surface */
  --card: #ffffff;
  --card-foreground: #030018;

  /* Layout & Sidebar */
  --sidebar: #ffffff;
  --subtle-foreground: #445469;
  --sidebar-border: #f2f4f7;
  --muted: #f9fafb;
  --muted-foreground: #98a2b3;
  --popover: #ffffff;
  --popover-foreground: #030018;

  /* Soft Modern Depth */
  --radius: 0.5rem;
  --shadow-color: rgba(3, 0, 24, 0.05);
  --border: #ebecf2;
  --ring: #12e193; /* Default ring to Emerald */

  /* Functional Colors */
  --accent: #f4fbf9;
  --accent-foreground: #12e193;
  --destructive: #e54b4f;
  --destructive-foreground: #ffffff;

  /* Status Tokens — use these instead of raw green/red/orange/blue */
  --status-success: #12a971;          /* emerald-darkened for text */
  --status-success-foreground: #ffffff;
  --status-success-soft: #ecfdf5;     /* light bg tint */
  --status-warning: #b45309;          /* amber-700 for text */
  --status-warning-foreground: #ffffff;
  --status-warning-soft: #fef3c7;     /* amber-100 */
  --status-danger: #c0363b;           /* destructive-darkened for text */
  --status-danger-foreground: #ffffff;
  --status-danger-soft: #fef2f2;      /* red-50 */
  --status-info: #1e6fd0;             /* blue-700 for text */
  --status-info-foreground: #ffffff;
  --status-info-soft: #eff6ff;        /* blue-50 */

  /* Chart Palette — categorical colors for Recharts + muted metric chips */
  --chart-1: #2563eb;        /* blue-600 */
  --chart-1-soft: #eff6ff;   /* blue-50 */
  --chart-2: #db2777;        /* pink-600 */
  --chart-2-soft: #fdf2f8;   /* pink-50 */
  --chart-3: #7c3aed;        /* violet-600 */
  --chart-3-soft: #f5f3ff;   /* violet-50 */
  --chart-4: #0d9488;        /* teal-600 (emerald-adjacent) */
  --chart-4-soft: #f0fdfa;   /* teal-50 */
  --chart-5: #ea580c;        /* orange-600 */
  --chart-5-soft: #fff7ed;   /* orange-50 */
  --chart-6: #1e293b;        /* slate-800 (navy) */
  --chart-6-soft: #f1f5f9;   /* slate-100 */

  /* Brand Colors */
  --facebook: #1877f2;
  --brand-meta: #0866ff;
  --brand-tiktok: #010101;
  --brand-tiktok-foreground: #ffffff;
  --google: #4285f4; /* Also commonly used: #DB4437, #F4B400, #0F9D58 */
  --spotify: #1db954;
  --whatsapp: #25D366;

  /* AI Branding */
  --ai: #8b5cf6; /* Violet 500 */
  --ai-foreground: #ffffff;

  /* Warning (yellow) — used for pixel prompts, advisory sections */
  --warning-bg: #fefce8;        /* yellow-50 */
  --warning-border: #fef08a;    /* yellow-200 */
  --warning-text: #713f12;      /* yellow-900 */
  --warning-text-secondary: #92400e; /* yellow-800 */
  --warning-icon: #ca8a04;      /* yellow-600 */
  --warning-icon-bg: #fef9c3;   /* yellow-100 */
  --warning-btn: #ca8a04;       /* yellow-600 */
  --warning-btn-hover: #a16207; /* yellow-700 */

  --shadow-card: 0 0 0 9px #f9fafb;
}

.dark {
  --background: #030018;
  --foreground: #ffffff;
  --card: #0a071e;
  --card-foreground: #ffffff;
  --popover: #05021a;
  --popover-foreground: #ffffff;
  --primary: #12e193;
  --primary-foreground: #030018;
  --sidebar: #05021a;
  --subtle-foreground: #cbd5e1; /* Slate 300 - lighter than muted */
  --sidebar-border: #1b1832;
  --border: #1b1832;
  --muted: #1b1832;
  --muted-foreground: #98a2b3;
  --ring: #12e193;
  --shadow-card: 0 0 0 9px #f9fafb;

