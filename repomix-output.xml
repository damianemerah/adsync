<file path="components/campaigns/new/wizard-tab-nav.tsx">
"use client";

import { TabsList, TabsTrigger } from "@/components/ui/tabs";
import { cn } from "@/lib/utils";

interface WizardTabNavProps {
  hasExtraStep: boolean;
  extraStepLabel: string;
  canGoTo: {
