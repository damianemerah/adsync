<file path="app/globals.css">
@import url("https://fonts.googleapis.com/css2?family=Montserrat+Alternates:wght@700&family=Montserrat:wght@400;500;600;700&display=swap");
@import "tailwindcss";
@import "tw-animate-css";

@custom-variant dark (&:is(.dark *));

:root {
  /* Wask Brand Colors */
  --primary: #12e193;
  --primary-foreground: #ffffff;
  --background: #ffffff;
  --foreground: #030018;

  /* Layout & Sidebar */
  --sidebar: #ffffff;
  --subtle-foreground: #445469;
  --sidebar-border: #f2f4f7;
  --muted: #f9fafb;
  --muted-foreground: #98a2b3;
  --popover: #ffffff;
  --popover-foreground: #030018;

  /* Soft Modern Depth */
  --radius: 1.5rem;
  --shadow-color: rgba(3, 0, 24, 0.05);
  --border: #ebecf2;
  --ring: #12e193; /* Default ring to Emerald */

  /* Functional Colors */
  --accent: #f4fbf9;
  --accent-foreground: #12e193;
  --destructive: #e54b4f;
  --destructive-foreground: #ffffff;

  /* Brand Colors */
  --facebook: #1877f2;
  --google: #4285f4; /* Also commonly used: #DB4437, #F4B400, #0F9D58 */
  --spotify: #1db954;

  /* AI Branding */
  --ai: #8b5cf6; /* Violet 500 */
  --ai-foreground: #ffffff;

  --shadow-card: 0 0 0 9px #f9fafb;
}

.dark {
  --background: #030018;
  --foreground: #ffffff;
  --card: #0a071e;
  --card-foreground: #ffffff;
  --popover: #05021a;
  --popover-foreground: #ffffff;
  --primary: #12e193;
  --primary-foreground: #030018;
  --sidebar: #05021a;
  --subtle-foreground: #cbd5e1; /* Slate 300 - lighter than muted */
  --border: #1b1832;
  --muted: #1b1832;
  --muted-foreground: #98a2b3;
  --ring: #12e193;
  --shadow-card: 0 0 0 9px #f9fafb;
}

@theme inline {
  --font-sans: "Montserrat", sans-serif;
  --font-heading: "Montserrat Alternates", sans-serif;

  /* Use --color-* prefix for variables to become color utilities */
  --color-primary: var(--primary);
  --color-primary-foreground: var(--primary-foreground);
  --color-background: var(--background);
  --color-foreground: var(--foreground);
  --color-muted: var(--muted);
  --color-muted-foreground: var(--muted-foreground);
  --color-popover: var(--popover);
  --color-popover-foreground: var(--popover-foreground);
  --color-accent: var(--accent);
  --color-accent-foreground: var(--accent-foreground);
  --color-destructive: var(--destructive);
  --color-border: var(--border);
  --color-ring: var(--ring); /* This enables outline-ring and ring utilities */
  --color-sidebar: var(--sidebar);
  --color-subtle-foreground: var(--subtle-foreground);
  --color-sidebar-border: var(--sidebar-border);

  --radius-lg: var(--radius);
  --shadow-soft: 0 4px 20px -2px var(--shadow-color);
  --shadow-card: 0 0 0 9px var(--shadow-card);

  /* Brand Utilities */
  --color-facebook: var(--facebook);
  --color-google: var(--google);
  --color-spotify: var(--spotify);

  /* AI Utilities */
  --color-ai: var(--ai);
  --color-ai-foreground: var(--ai-foreground);
}

@utility container {
  margin-inline: auto;
  /* padding-inline: 2rem; */
  max-width: 1400px;
  width: 100%;

  @media (width >= 640px) {
    max-width: 640px;
  }
  @media (width >= 768px) {
    max-width: 768px;
  }
  @media (width >= 1024px) {
    max-width: 1024px;
  }
  @media (width >= 1280px) {
    max-width: 1280px;
  }
  @media (width >= 1536px) {
    max-width: 1400px;
  }
}

@layer base {
  /* Applying outline to focus states or global reset */
  *:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--ring) 50%, transparent);
  }

  body {
    background-color: var(--background);
    color: var(--foreground);
    font-family: var(--font-sans);
  }

  h1,
  h2,
  h3 {
    font-family: var(--font-heading);
    font-weight: 700;
    letter-spacing: -0.025em;
  }

  .side-menu-sub-item {
    display: flex;
    align-items: center;
    gap: 8px;
    width: 100%;
    max-width: 200px;
    padding: 6px 8px;
    border-radius: 6px;
    background-color: #ffffff;
    color: var(--subtle-foreground);
    font-size: 14px;
    font-weight: 500;
    line-height: 1.25rem;
    cursor: pointer;
    transition: all 0.15s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .side-menu-item {
    align-items: center;
    border-radius: 6px;
    cursor: pointer;
    display: flex;
    font-size: 14px;
    font-weight: 500;
    gap: 12px;
    line-height: 20px;
    line-height: 1.25rem;
    margin-bottom: 6px;
    padding: 6px 8px;
    text-transform: capitalize;
    --tw-text-opacity: 1;
    color: var(--subtle-foreground);
  }

  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }

  .text-primary-foreground {
    color: var(--primary-foreground);
  }

  .head-section:before {
    background-image: url(/bg-hero.svg);
    background-position: 50%;
    content: "";
    height: 100%;
    left: 0;
    overflow: hidden !important;
    position: absolute;
    right: 0;
    text-align: -webkit-center;
    top: 0;
    width: 100%;
    z-index: -1 !important;
  }
}
