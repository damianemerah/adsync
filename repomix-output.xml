  },
];

// Meta Website/E-commerce CTAs
export const META_WEBSITE_CTAS: CTAOption[] = [
  {
    code: "SHOP_NOW",
    label: "Shop now",
    description: "Direct to product",
  },
  {
    code: "LEARN_MORE",
    label: "Learn more",
