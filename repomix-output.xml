  const model = obj?.optimizationModel || "click";

  switch (model) {
    case "conversation":
      return NG_BENCHMARKS.ctrEngagement; // Conversations behave like engagement CTR-wise
    case "click":
      return NG_BENCHMARKS.ctrTraffic;
    case "reach":
      return NG_BENCHMARKS.ctrAwareness;
    case "engagement":
