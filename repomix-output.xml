                <Command>
                  {/* ... content remains same ... */}
                  <CommandInput
                    placeholder="Search account..."
                    className="h-11 border-b-border"
                  />
                  <CommandList>
                    <CommandEmpty>No account found.</CommandEmpty>
                    <CommandGroup>
                      {filteredAccounts?.map((account) => (
                        <CommandItem
                          key={account.id}
                          value={account.name}
