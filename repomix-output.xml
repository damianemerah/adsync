      {/* Action Bar */}
      <div className="px-3 py-2 flex items-center justify-between">
        <div className="flex gap-3">
          <Heart className="h-5 w-5 text-slate-800" />
          <ChatBubble className="h-5 w-5 text-slate-800" />
