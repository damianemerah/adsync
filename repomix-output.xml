"use server";

import { COPY_COMPLETION_SYSTEM_PROMPT } from "@/lib/ai/prompts";
import { createClient } from "@/lib/supabase/server";
import OpenAI from "openai";

const openai = new OpenAI({ apiKey: process.env.OPENAI_API_KEY });

// Soft rate-limit: max text calls per org per hour (abuse guard)
const MAX_TEXT_CALLS_PER_HOUR = 100;

export interface AdCopyResult {
  headline: string;
  subHeadline: string;
  bodyCopy: string;
  ctaIntent: string;
  whatsappMessage?: string;
  vibeCheck: string;
}

export async function generateAdCopy(
  productDescription: string,
): Promise<AdCopyResult> {
  if (!productDescription) throw new Error("Description required");

  // ── Auth + org guard ───────────────────────────────────────────────────────
  // Text generation is FREE — no credits deducted — but we still require
  // an active account so anonymous callers can't abuse the OpenAI key.
  const supabase = await createClient();
  const { data: { user } } = await supabase.auth.getUser();
  if (!user) throw new Error("Unauthorized");

  const { data: member } = await supabase
    .from("organization_members")
    .select("organization_id, organizations(subscription_status)")
    .eq("user_id", user.id)
    .single();

  if (!member) throw new Error("No organization found");

  // @ts-ignore — nested join typing
  const status = member.organizations?.subscription_status as string | undefined;
  const allowedStatuses = ["active", "trialing"];
  if (status && !allowedStatuses.includes(status)) {
    throw new Error("Your subscription is inactive. Please renew to continue.");
  }

  // ── Soft hourly rate limit ─────────────────────────────────────────────────
  const oneHourAgo = new Date(Date.now() - 60 * 60 * 1000).toISOString();
  const { count } = await supabase
    .from("ai_requests")
    .select("id", { count: "exact", head: true })
    .eq("organization_id", member.organization_id as string)
    .eq("request_type", "text_generation")
    .gte("created_at", oneHourAgo);

  if ((count ?? 0) >= MAX_TEXT_CALLS_PER_HOUR) {
    throw new Error(
      "You've made too many requests in the last hour. Please wait a few minutes.",
    );
  }

  // ── Generate ───────────────────────────────────────────────────────────────
  const completion = await openai.chat.completions.create({
    model: "gpt-4o-mini",
    messages: [
      { role: "system", content: COPY_COMPLETION_SYSTEM_PROMPT },
      { role: "user", content: productDescription },
    ],
    response_format: { type: "json_object" },
  });

  const content = completion.choices[0].message.content;
  if (!content) throw new Error("Failed to generate ad copy");

  // ── Log request (for analytics, no cost charged) ───────────────────────────
  await supabase.from("ai_requests").insert({
    user_id: user.id,
    organization_id: member.organization_id as string,
    request_type: "text_generation",
    input_json: { prompt_length: productDescription.length },
    result_json: { generated: true },
    tokens_used: completion.usage?.total_tokens ?? 0,
  }).then(({ error }) => {
    if (error) console.error("[ai-text] Failed to log request:", error);
  });

  return JSON.parse(content);
}
